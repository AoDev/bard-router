{
  "include": ["./src/**/*", "./test/**/*", "./vitest.config.ts"],
  "compilerOptions": {
    "isolatedModules": true,
    "noEmit": true,
    "target": "esnext",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "inlineSourceMap": false,
    "inlineSources": false
  }
}
