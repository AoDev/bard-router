{
  "name": "bard-router",
  "version": "4.0.0-rc.0",
  "description": "More than just a routing solution, for React/Mobx applications",
  "homepage": "https://github.com/AoDev/bard-router",
  "main": "lib/index.js",
  "module": "esm/index.mjs",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./esm/index.mjs",
      "require": "./lib/index.js"
    },
    "./lib/*": "./lib/*",
    "./esm/*": "./esm/*"
  },
  "files": [
    "lib",
    "esm",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:error": "biome check . --diagnostic-level=error",
    "lint:fix": "biome lint --write .",
    "build": "del-cli lib esm && rslib build",
    "build:inspect": "rslib inspect --verbose",
    "prepare": "npm run build",
    "tag-release": "npm test && standard-version",
    "test-unit": "vitest run",
    "test": "vitest run"
  },
  "keywords": [
    "router",
    "react",
    "mobx"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:AoDev/bard-router.git"
  },
  "author": "AoDev",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^20.19.0 || >=22.12.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10.0.0",
      "onFail": "warn"
    }
  },
  "dependencies": {
    "history": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@rsbuild/plugin-react": "2.0.0",
    "@rslib/core": "0.21.2",
    "@testing-library/jest-dom": "6.1.4",
    "@testing-library/react": "14.0.0",
    "@testing-library/user-event": "14.5.1",
    "@types/history": "5.0.0",
    "@types/react": "18.2.33",
    "del-cli": "5.1.0",
    "jsdom": "29.1.0",
    "mobx": "6.10.2",
    "mobx-react": "9.0.1",
    "prettier": "3.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "standard-version": "9.5.0",
    "ts-node": "10.9.1",
    "typescript": "5.2.2",
    "vitest": "4.1.5"
  }
}
